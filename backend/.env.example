# Copy to .env and fill in. See DEPLOYMENT.md for the full self-host / SaaS runbooks.

# self_hosted | saas — see ARCHITECTURE.md §7 and FEATURE_TIERS.md
DEPLOYMENT_MODE=self_hosted

PORT=4000

# SQLite for dev/self-host; use a postgresql:// URL for production/SaaS scale
DATABASE_URL="file:./dev.db"

# Generate a long random value, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional - AI Assistant / Log Digest. Self-hosted: bring your own key.
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Optional - Email alert delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional - Slack/Discord/Teams/generic webhook alert delivery are configured per alert
# rule from the dashboard (channel spec like "slack:<webhook_url>"), not via env vars.

# Optional - Telegram alert delivery. One bot shared by the whole deployment; alert rules
# reference it via a channel spec like "telegram:<chat_id>".
TELEGRAM_BOT_TOKEN=

# Optional - SMS alert delivery via Twilio. Alert rules reference a channel spec like
# "sms:<phone_number>".
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Razorpay billing - ONLY read when DEPLOYMENT_MODE=saas. Get these from the Razorpay
# Dashboard (Settings -> API Keys, Settings -> Webhooks). Never commit real values;
# never paste them into chat/CI logs.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
